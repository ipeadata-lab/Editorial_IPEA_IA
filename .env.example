# Variáveis principais
# Use sempre LLM_PROVIDER + LLM_MODEL como configuração preferencial.
# LLM_BASE_URL e LLM_API_KEY valem para qualquer provider.

# OpenAI
LLM_PROVIDER=openai
LLM_MODEL=gpt-5.2
LLM_API_KEY=sk-sua-chave-aqui

# Endpoint compatível com OpenAI
# LLM_PROVIDER=openai_compatible
# LLM_BASE_URL=http://qwen3-235b.ipea.gov.br/v1/
# LLM_MODEL=Qwen/Qwen3-235B-A22B-Instruct-2507
# LLM_API_KEY="Authorization: Bearer"

# Ollama
# LLM_PROVIDER=ollama
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_MODEL=llama3.1:8b
# LLM_API_KEY=ollama

# Aliases legados ainda funcionam como fallback:
# OPENAI_API_KEY / OPENAI_MODEL / OPENAI_BASE_URL
# OLLAMA_API_KEY / OLLAMA_MODEL / OLLAMA_BASE_URL
